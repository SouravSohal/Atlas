# ATLAS Operations Dashboard Environment Variables
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development
VITE_WS_URL=ws://localhost:8000/ws
VITE_GEMINI_MODEL=gemini-2.5-pro
VITE_APP_VERSION=v0.9.4-rc2
VITE_DB_ENGINE=Cloud Firestore

# Telemetry Warning Thresholds
VITE_CROWD_DENSITY_THRESHOLD=75
VITE_QUEUE_TIME_THRESHOLD=15
VITE_AI_CONFIDENCE_THRESHOLD=80

# Simulation Default Settings
VITE_DEMO_MODE=true
VITE_SIMULATION_SPEED=2
