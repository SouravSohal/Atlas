# ==============================================================================
# ATLAS - Centralized Environment Configuration Template
# ==============================================================================

# --- Backend Application Information ---
APP_NAME=ATLAS
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0
APP_DEBUG=false

# --- Backend API Host/Port Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173

# --- Google Cloud Platform & Database ---
GOOGLE_CLOUD_PROJECT=atlas-501808
GOOGLE_CLOUD_REGION=us-central1
FIRESTORE_DATABASE=atlas-01
FIRESTORE_EMULATOR_HOST=

# --- Gemini AI Configuration ---
GEMINI_API_KEY=mock-api-key-replace-in-production
GEMINI_MODEL=gemini-2.5-pro

# --- Cryptography & Security ---
# Ensure to use a strong, unique, non-placeholder secret key (at least 32 characters long)
JWT_SECRET=your-strong-cryptographically-secure-jwt-signing-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Demo Mode Credentials Configuration ---
# Required in Development and Staging when DEMO_MODE=true or app environment is development.
# Required in Production to prevent unconfigured access. Do not use placeholders.
DEMO_EMAIL=your-configured-demo-admin@domain.com
DEMO_PASSWORD=your-strong-configured-demo-password-here


# --- Frontend Application Configurations (Vite Prefixed) ---
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development
VITE_WS_URL=ws://localhost:8000/ws
VITE_GEMINI_MODEL=gemini-2.5-pro
VITE_APP_VERSION=v0.9.4-rc2
VITE_DB_ENGINE=Cloud Firestore

# --- Frontend Telemetry Warning Thresholds ---
VITE_CROWD_DENSITY_THRESHOLD=75
VITE_QUEUE_TIME_THRESHOLD=15
VITE_AI_CONFIDENCE_THRESHOLD=80

# --- Frontend Simulation Default Settings ---
VITE_DEMO_MODE=true
VITE_SIMULATION_SPEED=2

# --- Simulation Demo Seed Path ---
# Configurable path to stadium_seed_data.json. If left empty, defaults to package resources.
DEMO__SEED_DATA_PATH=
