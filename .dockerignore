# Exclude virtual environments and caches recursively
**/.venv/
**/venv/
**/env/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.coverage
**/htmlcov/

# Exclude node modules and build outputs recursively
**/node_modules/
**/dist/
**/dist-ssr/

# Exclude git metadata
.git/
.github/
.gitignore
.editorconfig
.pre-commit-config.yaml

# Exclude IDE folders
.vscode/
.idea/
*.swp
*.swo

# Exclude development configurations and logs
.env
.env.example
*.log
scratch/

# Exclude documentation and local tools
docs/
scripts/
users/
infrastructure/
