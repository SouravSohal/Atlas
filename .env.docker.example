# ==============================================================================
# ATLAS Local Docker Runtime Environment Configuration Example
# ==============================================================================

# --- Core App Settings ---
ENVIRONMENT=development
APP_NAME=ATLAS Gateway
APP_VERSION=0.1.0
APP_DEBUG=true

# --- API Bind & CORS Settings ---
PORT=8000
API_HOST=0.0.0.0
# Comma-separated allowed domains. NOTE: Wildcard "*" is forbidden.
API_CORS_ORIGINS=http://localhost:5173

# --- Google Cloud & Database Infrastructure ---
# Identify target GCP project and Firestore instance
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE=your-firestore-database-name

# Path to service account key JSON inside the container.
# If running locally without metadata server, mount your key JSON file to /app/credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# --- Security & JWT Session Cryptography ---
JWT_SECRET=your-strong-cryptographically-secure-key-32-characters-minimum
JWT_EXPIRE_MINUTES=60

# --- Firebase Authentication ---
# Mock placeholder is allowed in development, but must be a real key in production
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain

# --- Gemini AI Configuration ---
# Mock placeholder is allowed in development, but must be a real key in production
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Demo & Seeding Configuration ---
DEMO_MODE=true
DEMO_EMAIL=demo@atlas.com
DEMO_PASSWORD=your-secure-demo-password
DEMO_ROLE=Administrator

# Path to Stadium Seed Data JSON (Uncomment only if overriding package resource)
# DEMO__SEED_DATA_PATH=/app/packages/atlas-core/src/atlas_core/resources/stadium_seed_data.json

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_JSON_FORMAT=false
